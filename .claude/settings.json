{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(task:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(go mod tidy)",
      "Bash(go mod vendor)",
      "Bash(go mod download)",
      "Bash(go mod verify)",
      "Bash(go mod why:*)",
      "Bash(go list:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go version)",
      "Bash(gofmt:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find . -type f:*)",
      "Bash(find . -name:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(file:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git commit --amend:*)"
    ]
  }
}
